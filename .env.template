#############################################################
# WorkAdventure 設定ファイル テンプレート
#
# このファイルをコピーして .env を作成します。
#   ./setup.sh   ... .env を自動生成し、秘密鍵をランダム生成します
#
# 必ず変更が必要なのは DOMAIN と ACME_EMAIL の2つだけです。
#############################################################

#############################################################
# 【最重要】ここだけは必ず設定してください
#############################################################

# WorkAdventure を公開するドメイン名。
#   - 独自ドメイン運用 : 例) wa.example.com （DNS をこのサーバーへ向ける）
#   - ローカル検証のみ : workadventure.localhost のままでも起動可能
#                        （ブラウザの証明書警告は出ます）
DOMAIN=workadventure.localhost

# Let's Encrypt の証明書更新通知に使うメールアドレス（公開ドメイン運用時は必須）。
# ローカル検証(.localhost)のみなら空のままで構いません。
ACME_EMAIL=

#############################################################
# 利用する Docker イメージのバージョン（安定版に固定）
#############################################################
VERSION=v1.31.7

#############################################################
# Security（秘密鍵） … setup.sh が空欄を自動生成します
#############################################################

# セッションデータの暗号化に使う秘密鍵（必須）。
SECRET_KEY=

# 外部 admin サーバーを使う場合のみ必要。通常は空のまま。
ADMIN_API_TOKEN=

#############################################################
# Networking
#############################################################

# SAAS admin パネル（セルフホストでは未使用）
ADMIN_API_URL=
ADMIN_URL=

#############################################################
# Basic configuration
#############################################################

# データ保存ディレクトリ（Let's Encrypt 証明書など）
DATA_DIR=./wa

# 最初に読み込まれるマップの URL。
#   既定値は公式スターターマップ（外部ホスト）です。すぐに動作確認できます。
#   自前のマップを map-storage にアップロードしたら "/~/<map名>.wam" に変更します。
START_ROOM_URL=/_/global/workadventure.github.io/map-starter-kit/office.tmj

# メニューに問い合わせページを表示したい場合のみ URL を設定
CONTACT_URL=

# 1つの会話バブルに入れる最大人数（既定 4）。
# Livekit を設定していない場合は増やさないでください。
MAX_PER_GROUP=4
MAX_USERNAME_LENGTH=10
DISABLE_ANONYMOUS=false

# P2P 接続でビデオ/画面共有が使う帯域（kbit/s）
PEER_VIDEO_LOW_BANDWIDTH=150
PEER_VIDEO_RECOMMENDED_BANDWIDTH=600
PEER_SCREEN_SHARE_LOW_BANDWIDTH=250
PEER_SCREEN_SHARE_RECOMMENDED_BANDWIDTH=1000

TZ=Asia/Tokyo

#############################################################
# Livekit（大人数のビデオ通話を使う場合のみ）
#############################################################
LIVEKIT_HOST=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Meeting Recording (Livekit Egress)
LIVEKIT_RECORDING_S3_ENDPOINT=
LIVEKIT_RECORDING_S3_CDN_ENDPOINT=
LIVEKIT_RECORDING_S3_ACCESS_KEY=
LIVEKIT_RECORDING_S3_SECRET_KEY=
LIVEKIT_RECORDING_S3_BUCKET=
LIVEKIT_RECORDING_S3_REGION=
LIVEKIT_PIXEL_DENSITY=0.6666666666666666

#############################################################
# Jitsi
#############################################################
JITSI_URL=meet.jit.si
JITSI_PRIVATE_MODE=false
JITSI_ISS=
SECRET_JITSI_KEY=

#############################################################
# BigBlueButton（既定はテスト用インスタンス。本番では変更を）
#############################################################
BBB_URL=https://test-install.blindsidenetworks.com/bigbluebutton/
BBB_SECRET=8cd8ef52e8e101574e400365b55e11a6

#############################################################
# Turn/Stun（NAT 越えに使用。自宅 NAT 環境では設定推奨）
#############################################################
TURN_SERVER=
TURN_USER=
TURN_PASSWORD=
TURN_STATIC_AUTH_SECRET=
# 公開の STUN を使うのが手軽です。
STUN_SERVER=stun:stun.l.google.com:19302

#############################################################
# 第三者アプリ連携（OpenID 等）… 通常は空のまま
#############################################################
OPENID_CLIENT_ID=
OPENID_CLIENT_SECRET=
OPENID_CLIENT_ISSUER=
OPENID_PROFILE_SCREEN_PROVIDER=
OPENID_LOGOUT_REDIRECT_URL=
OPENID_USERNAME_CLAIM=
OPENID_LOCALE_CLAIM=
OPENID_SCOPE=
OPENID_PROMPT=
FALLBACK_LOCALE=
OPENID_WOKA_NAME_POLICY=user_input

# Matrix（チャット用。未使用なら空のまま）
MATRIX_API_URI=
MATRIX_PUBLIC_URI=
MATRIX_ADMIN_USER=
MATRIX_ADMIN_PASSWORD=
MATRIX_DOMAIN=

#############################################################
# Advanced configuration（通常は変更不要）
#############################################################

# 公開ポート。自宅ルーターでポート開放する番号と合わせます。
HTTP_PORT=80
HTTPS_PORT=443
GRPC_PORT=50051

DISABLE_NOTIFICATIONS=false
SKIP_RENDER_OPTIMIZATIONS=false
STORE_VARIABLES_FOR_LOCAL_MAPS=true

DEBUG_MODE=false
LOG_LEVEL=WARN

# コンテナの再起動ポリシー（サーバー再起動後も自動起動）
RESTART_POLICY=unless-stopped

# uploader 用 AWS 設定（Redis を使うので通常は空のまま）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=

# uploader 用 Redis 設定
UPLOADER_REDIS_HOST=redis
UPLOADER_REDIS_PORT=
UPLOADER_REDIS_DB_NUMBER=0

#############################################################
# CHAT
#############################################################
ENABLE_CHAT=true
ENABLE_CHAT_UPLOAD=true
UPLOAD_MAX_FILESIZE=10485760
ENABLE_CHAT_ONLINE_LIST=true
ENABLE_CHAT_DISCONNECTED_LIST=true
CLIENT_DISCONNECTION_RETENTION_MS=30000
ENABLE_TUTORIAL=true
EMBEDLY_KEY=

PROMETHEUS_AUTHORIZATION_TOKEN=

PLAYER_VARIABLES_MAX_TTL=-1

ENABLE_REPORT_ISSUES_MENU=false
REPORT_ISSUES_URL=

# テレメトリ（バージョンとおおまかな利用状況のみ送信。個人情報なし）
ENABLE_TELEMETRY=
SECURITY_EMAIL=

#############################################################
# MAP EDITOR（マップ編集機能）
#############################################################
ENABLE_MAP_EDITOR=true
FEATURE_FLAG_BROADCAST_AREAS=
# 編集を許可するユーザーを限定する場合（OpenID 設定時のみ有効）
MAP_EDITOR_ALLOWED_USERS=
# 全ユーザーに編集を許可（既定 true）
MAP_EDITOR_ALLOW_ALL_USERS=true

#############################################################
# map-storage の認証方式
#   Basic 認証を既定で有効化。ユーザー名/パスワードは setup.sh が生成します。
#############################################################
MAP_STORAGE_ENABLE_BEARER_AUTHENTICATION=false
MAP_STORAGE_ENABLE_BASIC_AUTHENTICATION=true
MAP_STORAGE_ENABLE_DIGEST_AUTHENTICATION=false
MAP_STORAGE_AUTHENTICATION_STRATEGY=
MAP_STORAGE_AUTHENTICATION_TOKEN=
MAP_STORAGE_AUTHENTICATION_VALIDATOR_URL=
MAP_STORAGE_AUTHENTICATION_USER=admin
MAP_STORAGE_AUTHENTICATION_PASSWORD=

MAP_STORAGE_API_TOKEN=
WHITELISTED_RESOURCE_URLS=

# Room API を使う場合の秘密鍵（setup.sh が生成）。空ならRoom APIは無効。
ROOM_API_SECRET_KEY=

#############################################################
# Sentry（エラー監視。未使用なら空のまま）
#############################################################
SENTRY_DSN_FRONT=
SENTRY_DSN_PUSHER=
SENTRY_DSN_MAPSTORAGE=
SENTRY_DSN_BACK=
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_TRACES_SAMPLE_RATE=

#############################################################
# Integration tools
#############################################################
KLAXOON_ENABLED=false
KLAXOON_CLIENT_ID=
YOUTUBE_ENABLED=true
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DOCS_ENABLED=true
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SLIDES_ENABLED=true
ERASER_ENABLED=true
EXCALIDRAW_ENABLED=true
EXCALIDRAW_DOMAINS=excalidraw.com
CARDS_ENABLED=true
TLDRAW_ENABLED=true
EMBEDDED_DOMAINS_WHITELIST=

GOOGLE_DRIVE_PICKER_CLIENT_ID=
GOOGLE_DRIVE_PICKER_APP_ID=

MAX_USERS_FOR_WEBRTC=4

# Conversation bubble
MINIMUM_DISTANCE=64
GROUP_RADIUS=48
