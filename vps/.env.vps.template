#############################################################
# VPS(玄関)側 設定テンプレート
#
#   このファイルをコピーして .env.vps を作成します。
#     ./setup-vps.sh   ... .env.vps を作成し、動的設定(dynamic/wa.yml)を生成します
#############################################################

# WorkAdventure を公開する公開ドメイン名。
# このドメインの DNS A レコードを VPS のグローバル IP に向けてください。
DOMAIN=wa.example.com

# Let's Encrypt の証明書更新通知に使うメールアドレス（必須）。
ACME_EMAIL=you@example.com

# 自宅サーバーへ転送する内部IP（トンネル上のIP。DNS に入れる IP とは別物）。
#   - Tailscale（推奨）: 自宅で `tailscale ip -4` を実行して表示される 100.x.x.x
#   - 素WireGuard      : setup-tunnel.sh の既定なら 10.8.0.2
HOME_WG_IP=

# Traefik のログレベル / コンテナ再起動ポリシー
LOG_LEVEL=WARN
RESTART_POLICY=unless-stopped
